<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="com.academy.third.country.persistence.Country" table="country" catalog="person_db"
           optimistic-lock="version">
        <id name="countryId" type="java.lang.Integer">
            <column name="country_id"/>
            <generator class="identity"/>
        </id>
        <property name="country" type="java.lang.String">
            <column name="country" length="50" not-null="true"/>
        </property>
        <property name="lastUpdate" type="java.sql.Timestamp" insert="false" update="false">
            <column name="last_update" not-null="true"/>
        </property>
    </class>
</hibernate-mapping>